{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "dist-demo", "demo", "node_modules"]
}
